{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "customConditions": ["development"],
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": ["node", "vite/client"]
  },
  "include": ["packages/*/src", "src", "vite.config.ts"]
}
